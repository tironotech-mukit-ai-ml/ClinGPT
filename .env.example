# ===========================================
# InTEAM AI Service - Environment Configuration
# ===========================================
# This file works for BOTH Quick Start (SQLite) and Docker (PostgreSQL) modes
# Copy this file to .env and fill in your actual values

# ===========================================
# REQUIRED: OpenAI Configuration
# ===========================================
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# ===========================================
# Django Configuration
# ===========================================
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# ===========================================
# Database Configuration
# ===========================================
# For Quick Start mode: SQLite (default) - no configuration needed
# For Docker mode: PostgreSQL - REQUIRED for docker-compose

# PostgreSQL Database (REQUIRED for Docker mode)
# ⚠️ IMPORTANT: Change these values before using Docker!
POSTGRES_DB=your_database_name
POSTGRES_USER=your_database_user
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://your_database_user:your_secure_password_here@postgres:5432/your_database_name

# ===========================================
# Cache Configuration
# ===========================================
# Redis Cache URL (used by Docker)
REDIS_URL=redis://redis:6379/0

# ===========================================
# Celery Configuration
# ===========================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ===========================================
# Laravel Integration
# ===========================================
LARAVEL_API_URL=http://localhost:80
LARAVEL_API_KEY=your-laravel-api-key-here

# ===========================================
# Guardrails Configuration (PHI Detection)
# ===========================================
GUARDRAILS_ENABLED=True
GUARDRAILS_LOG_PHI_DETECTIONS=True
SPACY_MODEL=en_core_web_sm

# ===========================================
# RAG Configuration (Vector Database)
# ===========================================
RAG_ENABLED=True
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_EMBEDDING_DIMENSION=384
RAG_TOP_K_RESULTS=5
RAG_SIMILARITY_THRESHOLD=0.5

# ===========================================
# Production Settings (set these in production)
# ===========================================
# DEBUG=False
# SECRET_KEY=generate-a-secure-random-secret-key
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# GUARDRAILS_ENABLED=True
# RAG_ENABLED=True
